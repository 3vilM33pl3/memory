[Unit]
Description=Memory Layer Service
After=network.target postgresql.service

[Service]
Type=simple
User=memory-layer
Group=memory-layer
EnvironmentFile=/etc/memory-layer/memory-layer.env
WorkingDirectory=/var/lib/memory-layer
ExecStart=/usr/bin/mem-service /etc/memory-layer/memory-layer.toml
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/memory-layer /var/log/memory-layer /etc/memory-layer

[Install]
WantedBy=multi-user.target
